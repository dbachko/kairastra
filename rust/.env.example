# Copy to rust/.env and fill in the values before running docker compose.

# Required for the GitHub tracker.
# For Projects v2 on a user-owned GitHub project, use a classic PAT.
# Recommended scopes: `project`, `repo` (if the repo is private), and
# `workflow` if agent changes may touch `.github/workflows/`.
GITHUB_TOKEN=

# Deployment mode hint used by setup/doctor.
SYMPHONY_DEPLOY_MODE=docker

# OpenAI API key for Codex API-key auth.
OPENAI_API_KEY=

# Anthropic API key for Claude API-key auth.
ANTHROPIC_API_KEY=

# Gemini API key for Gemini API-key auth.
# GOOGLE_API_KEY also works if you prefer Google's broader env name.
GEMINI_API_KEY=

# Optional long-lived Claude subscription token generated by Symphony's Docker Claude login
# flow or by a separate working Claude Code install.
# Docker login persists the same value into the shared Claude auth volume automatically.
CLAUDE_CODE_OAUTH_TOKEN=

# Codex auth mode: auto (prefer OPENAI_API_KEY, else persisted login),
# api_key (require/use OPENAI_API_KEY bootstrap), or subscription
# (device login via persisted Docker auth state).
CODEX_AUTH_MODE=auto

# Claude auth mode: auto (prefer ANTHROPIC_API_KEY, else persisted subscription token/login),
# api_key (require/use ANTHROPIC_API_KEY), or subscription.
CLAUDE_AUTH_MODE=auto

# Gemini auth mode: auto (prefer GEMINI_API_KEY, else persisted Google login),
# api_key (require/use GEMINI_API_KEY), or subscription.
GEMINI_AUTH_MODE=auto

# Optional password used to create/unlock the headless Docker keyring that
# Claude subscription auth uses. Leave empty to use a blank password.
SYMPHONY_CLAUDE_KEYRING_PASSWORD=

# Host path to the workflow file you want Symphony to load.
# Relative paths are resolved from rust/compose.yml.
WORKFLOW_FILE=../WORKFLOW.md

# Host path to the repository copy used to seed per-issue workspaces.
# Relative paths are resolved from rust/compose.yml.
SEED_REPO_PATH=..

# Workflow values passed through to the container so env-backed WORKFLOW.md fields resolve.
SYMPHONY_GITHUB_OWNER=
SYMPHONY_GITHUB_REPO=
SYMPHONY_GITHUB_PROJECT_NUMBER=
SYMPHONY_GITHUB_PROJECT_URL=
SYMPHONY_CLAUDE_MODEL=
SYMPHONY_CLAUDE_REASONING_EFFORT=
SYMPHONY_CODEX_MODEL=
SYMPHONY_CODEX_REASONING_EFFORT=
SYMPHONY_CODEX_FAST=false
KAIRASTRA_GEMINI_MODEL=
KAIRASTRA_GEMINI_APPROVAL_MODE=yolo

# Optional canonical clone/push URLs used by the default workflow template.
SYMPHONY_GIT_CLONE_URL=
SYMPHONY_GIT_PUSH_URL=

# Optional dispatch filter and git identity for worker branches.
SYMPHONY_AGENT_ASSIGNEE=
SYMPHONY_GIT_AUTHOR_NAME=Symphony
SYMPHONY_GIT_AUTHOR_EMAIL=symphony@users.noreply.github.com

# The workspace root inside the container. Your WORKFLOW.md should usually use:
# workspace:
#   root: $SYMPHONY_WORKSPACE_ROOT
SYMPHONY_WORKSPACE_ROOT=/workspaces

# Optional container logging level.
RUST_LOG=info

# Optional Codex CLI version baked into the image.
CODEX_CLI_VERSION=0.114.0

# Optional Claude Code CLI version baked into the image.
CLAUDE_CODE_VERSION=2.1.81

# Optional Gemini CLI version baked into the image.
GEMINI_CLI_VERSION=0.35.0
